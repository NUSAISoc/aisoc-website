---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { TeamMemberCard } from "@/components/react/TeamMemberCard";
import { getCollection } from "astro:content";

const teamMembers = await getCollection("team", ({ id }) => !id.startsWith("_template-"));
const sortedTeam = teamMembers.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Team">
    <div class="space-y-16">
        {/* Page Header */}
        <div class="space-y-4 border-b border-border pb-8">
            <h1 class="text-4xl md:text-5xl font-display font-bold tracking-tighter uppercase text-foreground">
                Core Team
            </h1>
            <p class="text-muted-foreground font-mono max-w-2xl">
                The people behind AISOC.
            </p>
        </div>

        {/* Team Grid */}
        <section>
            {
                sortedTeam.length > 0 ? (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                        {sortedTeam.map((member) => (
                            <TeamMemberCard client:load member={member} />
                        ))}
                    </div>
                ) : (
                    <div class="data-terminal text-center py-12 text-muted-foreground">[ NO_TEAM_MEMBERS_FOUND ]</div>
                )
            }
        </section>
    </div>
</BaseLayout>
