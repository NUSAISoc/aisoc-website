---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { SOCIAL_LINKS } from "@/lib/socialLinks";
import BentoCard from "@/components/BentoCard.astro";
import InitiativeCard from "@/components/InitiativeCard.astro";
import LinkCard from "@/components/LinkCard.astro";
import {
    IconArrowRight,
    IconClock,
    IconMapPin,
    IconTerminal,
    IconCpu,
    IconNetwork,
    IconSend,
    IconMessageCircle,
    IconBrandLinkedin,
    IconBrandTwitter,
    IconMail,
    IconRobot,
} from "@tabler/icons-react";

// Get next upcoming event
const allEvents = await getCollection("events", ({ id }) => !id.startsWith("_template-"));
const now = new Date();
const oneWeekFromNow = new Date(now.getTime() + 7 * 24 * 60 * 60 * 1000);

const upcomingEvents = allEvents
    .filter((event) => event.data.status === "upcoming" || new Date(event.data.date) >= now)
    .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const upcomingEvent = upcomingEvents[0];
const nextEvent = upcomingEvent && new Date(upcomingEvent.data.date) <= oneWeekFromNow ? upcomingEvent : null;

const formatDate = (date: Date) => {
    return new Intl.DateTimeFormat("en-SG", {
        weekday: "short",
        day: "numeric",
        month: "short",
    }).format(date);
};
---

<BaseLayout title="NUS SoC AI Society">
    <div
        class="min-h-screen bg-background text-foreground font-sans selection:bg-primary selection:text-primary-foreground"
    >
        <!-- Main Grid Container -->
        <main class="container mx-auto px-4 md:px-6 py-8">
            <div class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-4 auto-rows-min">
                <!-- 1. Hero Section (Top Left - Large) -->
                <BentoCard
                    variant="hero"
                    class={`col-span-1 md:col-span-6 ${nextEvent ? "lg:col-span-8" : "lg:col-span-12"} min-h-[500px] flex flex-col justify-center p-8 md:p-12`}
                >
                    <!-- Background decoration: Grid + Radial -->
                    <div
                        class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
                    >
                    </div>

                    <div class="space-y-8 z-10 max-w-3xl">
                        <h1
                            class="text-6xl md:text-7xl lg:text-8xl font-display font-black uppercase tracking-tighter leading-[0.9]"
                        >
                            NUS SoC<br />
                            <span class="text-primary">AI SOCIETY</span>
                        </h1>

                        <p class="text-xl text-muted-foreground font-mono leading-relaxed max-w-xl">
                            The Student Hub for AI Research & Engineering.
                        </p>
                        <div class="flex flex-wrap gap-8 pt-4">
                            <a
                                href="/events"
                                class="inline-flex items-center text-lg font-mono uppercase tracking-widest text-primary hover:text-primary/80 transition-colors group/link cursor-pointer"
                            >
                                [ Explore Events ] <IconArrowRight
                                    className="ml-2 h-5 w-5 group-hover/link:translate-x-1 transition-transform"
                                />
                            </a>
                            <a
                                href="/team"
                                class="inline-flex items-center text-lg font-mono uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors group/link cursor-pointer"
                            >
                                [ Meet The Team ] <IconArrowRight
                                    className="ml-2 h-5 w-5 opacity-0 -ml-5 group-hover/link:opacity-100 group-hover/link:ml-2 transition-all"
                                />
                            </a>
                        </div>
                    </div>
                </BentoCard>

                <!-- 2. Next Event (Top Right - Medium) -->
                {
                    nextEvent && (
                        <BentoCard variant="event" class="col-span-1 md:col-span-6 lg:col-span-4 flex flex-col">
                            {nextEvent.data.image && (
                                <div class="absolute inset-0 z-0">
                                    <img
                                        src={nextEvent.data.image}
                                        alt={nextEvent.data.title}
                                        class="w-full h-full object-cover opacity-30 group-hover:opacity-40 transition-all duration-700 group-hover:scale-105 filter grayscale group-hover:grayscale-0"
                                    />
                                    <div class="absolute inset-0 bg-gradient-to-t from-background via-background/80 to-background/20" />
                                </div>
                            )}
                            <div class="absolute top-0 right-0 z-20 bg-primary/20 text-primary px-3 py-1 font-mono text-xs uppercase tracking-widest backdrop-blur-sm border-l border-b border-primary/20">
                                Next Up
                            </div>
                            <div class="p-8 flex flex-col h-full justify-between relative z-10">
                                <div class="space-y-6">
                                    <div class="space-y-2">
                                        <p class="text-primary font-mono text-sm uppercase tracking-wide">
                                            {formatDate(new Date(nextEvent.data.date))}
                                        </p>
                                        <h3 class="text-3xl font-display uppercase tracking-tight leading-none group-hover:text-primary transition-colors">
                                            {nextEvent.data.title}
                                        </h3>
                                    </div>

                                    <div class="space-y-3 text-sm text-muted-foreground font-mono border-l-2 border-primary/20 pl-4">
                                        <div class="flex items-center gap-3">
                                            <IconClock className="h-4 w-4 text-primary" />
                                            <span>{nextEvent.data.time}</span>
                                        </div>
                                        <div class="flex items-center gap-3">
                                            <IconMapPin className="h-4 w-4 text-primary" />
                                            <span>{nextEvent.data.location}</span>
                                        </div>
                                    </div>

                                    {nextEvent.data.description && (
                                        <p class="text-muted-foreground line-clamp-3 text-sm font-mono">
                                            {nextEvent.data.description}
                                        </p>
                                    )}
                                </div>

                                <div class="mt-6 border-t border-border pt-4">
                                    <a
                                        href={`/events/${nextEvent.slug}`}
                                        class="inline-flex items-center text-sm font-mono text-primary uppercase tracking-widest hover:translate-x-1 transition-transform"
                                    >
                                        [ View Details ] <IconArrowRight className="ml-2 h-3 w-3" />
                                    </a>
                                </div>
                            </div>
                        </BentoCard>
                    )
                }

                <!-- 3. Mission Statement (Full Width) -->
                <BentoCard variant="mission" class="col-span-1 md:col-span-6 lg:col-span-12 p-8 md:p-12">
                    <div class="flex-shrink-0">
                        <div
                            class="w-16 h-16 border-2 border-primary flex items-center justify-center rounded-full bg-primary/10"
                        >
                            <IconTerminal className="h-8 w-8 text-primary" />
                        </div>
                    </div>
                    <div class="space-y-4 w-full">
                        <h2
                            class="text-2xl font-display uppercase tracking-tight text-foreground flex items-center gap-3"
                        >
                            Who We Are <span class="h-px flex-1 bg-border ml-4"></span>
                        </h2>
                        <p class="text-lg md:text-xl text-muted-foreground leading-relaxed font-mono">
                            We are an insatiably curious community of students exploring the frontier of 
                            Artificial Intelligence. <br\> <br\> At AISoc, we like to slow down and peek under the hood. 
                            We examine fundamental ideas and ask questions that push our understanding further.
                        </p>
                    </div>
                </BentoCard>

                <!-- 4. Core Initiatives -->
                <div class="col-span-1 md:col-span-6 lg:col-span-12 pt-8">
                    <h2
                        class="text-2xl font-display uppercase tracking-tight mb-6 flex items-center gap-4 text-muted-foreground"
                    >
                        <span class="text-primary">Core Initiatives</span>
                        <div class="h-px flex-1 bg-border"></div>
                    </h2>
                </div>

                <!-- Democratise -->
                <InitiativeCard
                    icon={IconTerminal}
                    title="Open Access"
                    description="We help students get started on their journey into Artificial Intelligence and Machine Learning with beginner-friendly sharings."
                />

                <!-- Drive -->
                <InitiativeCard
                    icon={IconCpu}
                    title="Technical Sharings"
                    description="Members lead paper readings, lightning talks, and discussions that explore recent research and ideas. We also invite industry practitioners and researchers to share their perspectives."
                />

                <!-- Connect -->
                <InitiativeCard
                    icon={IconNetwork}
                    title="Community and Synthesis"
                    description="We cultivate an environment where curiosity and collaboration is valued, empowering members to share ideas, ask difficult questions, and work together on challenging problems."
                />

                <!-- 5. Community & Contact -->
                <div class="col-span-1 md:col-span-6 lg:col-span-12 pt-8">
                    <h2
                        class="text-2xl font-display uppercase tracking-tight mb-6 flex items-center gap-4 text-muted-foreground"
                    >
                        <span class="text-primary">Join The Network</span>
                        <div class="h-px flex-1 bg-border"></div>
                    </h2>
                </div>

                <!-- Telegram Main (Large) -->
                <LinkCard
                    href={SOCIAL_LINKS.telegramDiscussion.href}
                    target="_blank"
                    variant="large"
                    icon={IconSend}
                    title="Telegram Discussion"
                    subtitle="Open public forum. 500+ members."
                />

                <!-- Telegram Alerts (Large) -->
                <LinkCard
                    href={SOCIAL_LINKS.telegramAlerts.href}
                    target="_blank"
                    variant="large"
                    icon={IconSend}
                    title="Telegram Alerts"
                    subtitle="Official event announcements. No noise."
                />

                <!-- Discord (Large) -->
                <LinkCard
                    href={SOCIAL_LINKS.discord.href}
                    target="_blank"
                    variant="large"
                    icon={IconMessageCircle}
                    iconHighlight
                    title="Discord Workspace"
                    subtitle="The central operating system."
                    badge="Join Server"
                    class="md:col-span-6"
                />

                <!-- LinkedIn -->
                <LinkCard href={SOCIAL_LINKS.linkedin.href} target="_blank" icon={IconBrandLinkedin} title="LinkedIn" />

                <!-- X (Twitter) -->
                <LinkCard
                    href={SOCIAL_LINKS.twitter.href}
                    target="_blank"
                    icon={IconBrandTwitter}
                    title="X / Twitter"
                />

                <!-- Email -->
                <LinkCard href={SOCIAL_LINKS.email.href} icon={IconMail} title="Email" />

                <!-- Hugging Face -->
                <LinkCard href={SOCIAL_LINKS.huggingFace.href} target="_blank" icon={IconRobot} title="Hugging Face" />
            </div>
        </main>
    </div>
</BaseLayout>
