---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Button } from "@/components/ui/button";
import {
    IconArrowRight,
    IconClock,
    IconMapPin,
    IconTerminal,
    IconCpu,
    IconNetwork,
    IconSend,
    IconMessageCircle,
    IconBrandLinkedin,
    IconBrandTwitter,
    IconMail,
    IconRobot,
} from "@tabler/icons-react";

// Get next upcoming event
const allEvents = await getCollection("events");
const now = new Date();
const upcomingEvents = allEvents
    .filter((event) => event.data.status === "upcoming" || new Date(event.data.date) >= now)
    .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());
const nextEvent = upcomingEvents[0];

const formatDate = (date: Date) => {
    return new Intl.DateTimeFormat("en-SG", {
        weekday: "short",
        day: "numeric",
        month: "short",
    }).format(date);
};
---

<BaseLayout title="NUS SoC AI Society">
    <div
        class="min-h-screen bg-background text-foreground font-sans selection:bg-primary selection:text-primary-foreground"
    >
        <!-- Main Grid Container -->
        <main class="container mx-auto px-4 md:px-6 py-8">
            <div class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-4 auto-rows-min">
                <!-- 1. Hero Section (Top Left - Large) -->
                <div
                    class="col-span-1 md:col-span-6 lg:col-span-8 min-h-[500px] flex flex-col justify-center p-8 md:p-12 border border-border bg-card/10 relative overflow-hidden group"
                >
                    <!-- Background decoration: Grid + Radial -->
                    <div
                        class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
                    >
                    </div>

                    <div class="space-y-8 z-10 max-w-3xl">
                        <h1
                            class="text-6xl md:text-7xl lg:text-8xl font-display font-black uppercase tracking-tighter leading-[0.9]"
                        >
                            NUS SoC<br />
                            <span class="text-primary">AI SOCIETY</span>
                        </h1>

                        <p class="text-xl text-muted-foreground font-mono leading-relaxed max-w-xl">
                            The Student Hub for Machine Learning & Engineering. <br />
                            From Theory to Deployment.
                        </p>

                        <div class="flex flex-wrap gap-8 pt-4">
                            <a
                                href="/events"
                                class="inline-flex items-center text-lg font-mono uppercase tracking-widest text-primary hover:text-primary/80 transition-colors group/link cursor-pointer"
                            >
                                [ Explore Events ] <IconArrowRight
                                    className="ml-2 h-5 w-5 group-hover/link:translate-x-1 transition-transform"
                                />
                            </a>
                            <a
                                href="/team"
                                class="inline-flex items-center text-lg font-mono uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors group/link cursor-pointer"
                            >
                                [ Meet The Team ] <IconArrowRight
                                    className="ml-2 h-5 w-5 opacity-0 -ml-5 group-hover/link:opacity-100 group-hover/link:ml-2 transition-all"
                                />
                            </a>
                        </div>
                    </div>
                </div>

                <!-- 2. Next Event (Top Right - Medium) -->
                <div
                    class="col-span-1 md:col-span-6 lg:col-span-4 flex flex-col border border-border bg-card/20 relative overflow-hidden group hover:border-primary/50 transition-colors"
                >
                    {
                        nextEvent ? (
                            <>
                                {nextEvent.data.image && (
                                    <div class="absolute inset-0 z-0">
                                        <img
                                            src={nextEvent.data.image}
                                            alt={nextEvent.data.title}
                                            class="w-full h-full object-cover opacity-30 group-hover:opacity-40 transition-all duration-700 group-hover:scale-105 filter grayscale group-hover:grayscale-0"
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-background via-background/80 to-background/20" />
                                    </div>
                                )}
                                <div class="absolute top-0 right-0 z-20 bg-primary/20 text-primary px-3 py-1 font-mono text-xs uppercase tracking-widest backdrop-blur-sm border-l border-b border-primary/20">
                                    Next Up
                                </div>
                                <div class="p-8 flex flex-col h-full justify-between relative z-10">
                                    <div class="space-y-6">
                                        <div class="space-y-2">
                                            <p class="text-primary font-mono text-sm uppercase tracking-wide">
                                                {formatDate(new Date(nextEvent.data.date))}
                                            </p>
                                            <h3 class="text-3xl font-display uppercase tracking-tight leading-none group-hover:text-primary transition-colors">
                                                {nextEvent.data.title}
                                            </h3>
                                        </div>

                                        <div class="space-y-3 text-sm text-muted-foreground font-mono border-l-2 border-primary/20 pl-4">
                                            <div class="flex items-center gap-3">
                                                <IconClock className="h-4 w-4 text-primary" />
                                                <span>{nextEvent.data.time}</span>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <IconMapPin className="h-4 w-4 text-primary" />
                                                <span>{nextEvent.data.location}</span>
                                            </div>
                                        </div>

                                        {nextEvent.data.description && (
                                            <p class="text-muted-foreground line-clamp-3 text-sm font-mono">
                                                {nextEvent.data.description}
                                            </p>
                                        )}
                                    </div>

                                    <div class="mt-6 border-t border-border pt-4">
                                        <a
                                            href={`/events/${nextEvent.slug}`}
                                            class="inline-flex items-center text-sm font-mono text-primary uppercase tracking-widest hover:translate-x-1 transition-transform"
                                        >
                                            [ View Details ] <IconArrowRight className="ml-2 h-3 w-3" />
                                        </a>
                                    </div>
                                </div>
                            </>
                        ) : (
                            <div class="p-8 flex flex-col items-center justify-center h-full text-center space-y-4">
                                <IconClock className="h-12 w-12 text-muted-foreground/20" />
                                <p class="text-muted-foreground font-mono">No upcoming events scheduled.</p>
                                <div class="mt-6 border-t border-border pt-4 w-full">
                                    <a
                                        href="/events"
                                        class="inline-flex items-center text-sm font-mono text-muted-foreground hover:text-primary uppercase tracking-widest hover:translate-x-1 transition-transform"
                                    >
                                        [ Check Archive ] <IconArrowRight className="ml-2 h-3 w-3" />
                                    </a>
                                </div>
                            </div>
                        )
                    }
                </div>

                <!-- 3. Mission Statement (Full Width) -->
                <div
                    class="col-span-1 md:col-span-6 lg:col-span-12 flex flex-col md:flex-row items-center border border-border bg-card/20 p-8 md:p-12 gap-8 hover:border-primary/30 transition-colors"
                >
                    <div class="flex-shrink-0">
                        <div
                            class="w-16 h-16 border-2 border-primary flex items-center justify-center rounded-full bg-primary/10"
                        >
                            <IconTerminal className="h-8 w-8 text-primary" />
                        </div>
                    </div>
                    <div class="space-y-4 w-full">
                        <h2
                            class="text-2xl font-display uppercase tracking-tight text-foreground flex items-center gap-3"
                        >
                            Our Mission <span class="h-px flex-1 bg-border ml-4"></span>
                        </h2>
                        <p class="text-lg md:text-xl text-muted-foreground leading-relaxed font-mono">
                            We are a student-led engineering collective bridging the gap between academic theory and
                            deployment. We equip people of all skill levels with production-grade ML capabilities
                            through masterclasses, research groups, and hacks.
                        </p>
                    </div>
                </div>

                <!-- 4. Core Initiatives (Pillars) -->
                <div class="col-span-1 md:col-span-6 lg:col-span-12 pt-8">
                    <h2
                        class="text-2xl font-display uppercase tracking-tight mb-6 flex items-center gap-4 text-muted-foreground"
                    >
                        <span class="text-primary">Core Initiatives</span>
                        <div class="h-px flex-1 bg-border"></div>
                    </h2>
                </div>

                <!-- Democratise -->
                <div
                    class="col-span-1 md:col-span-2 lg:col-span-4 p-8 border border-border bg-card/20 hover:bg-card/40 hover:border-primary/50 transition-all group cursor-default"
                >
                    <div
                        class="w-12 h-12 border border-border flex items-center justify-center mb-6 group-hover:border-primary group-hover:bg-primary/10 transition-colors"
                    >
                        <IconTerminal
                            className="h-6 w-6 text-muted-foreground group-hover:text-primary transition-colors"
                        />
                    </div>
                    <h3
                        class="text-xl font-display uppercase tracking-tight mb-3 group-hover:text-primary transition-colors"
                    >
                        Open Access
                    </h3>
                    <p class="text-muted-foreground font-mono text-sm leading-relaxed">
                        Democratising AI education with workshops for all skill levels. From Python basics to
                        Transformer architecture, we make intelligence accessible.
                    </p>
                </div>

                <!-- Drive -->
                <div
                    class="col-span-1 md:col-span-2 lg:col-span-4 p-8 border border-border bg-card/20 hover:bg-card/40 hover:border-primary/50 transition-all group cursor-default"
                >
                    <div
                        class="w-12 h-12 border border-border flex items-center justify-center mb-6 group-hover:border-primary group-hover:bg-primary/10 transition-colors"
                    >
                        <IconCpu className="h-6 w-6 text-muted-foreground group-hover:text-primary transition-colors" />
                    </div>
                    <h3
                        class="text-xl font-display uppercase tracking-tight mb-3 group-hover:text-primary transition-colors"
                    >
                        Project Build
                    </h3>
                    <p class="text-muted-foreground font-mono text-sm leading-relaxed">
                        Driving innovation through hands-on development. We deploy solutions to real-world problems and
                        build the future, one epoch at a time.
                    </p>
                </div>

                <!-- Connect -->
                <div
                    class="col-span-1 md:col-span-2 lg:col-span-4 p-8 border border-border bg-card/20 hover:bg-card/40 hover:border-primary/50 transition-all group cursor-default"
                >
                    <div
                        class="w-12 h-12 border border-border flex items-center justify-center mb-6 group-hover:border-primary group-hover:bg-primary/10 transition-colors"
                    >
                        <IconNetwork
                            className="h-6 w-6 text-muted-foreground group-hover:text-primary transition-colors"
                        />
                    </div>
                    <h3
                        class="text-xl font-display uppercase tracking-tight mb-3 group-hover:text-primary transition-colors"
                    >
                        Network Sync
                    </h3>
                    <p class="text-muted-foreground font-mono text-sm leading-relaxed">
                        Connecting students with industry leaders and research pioneers. A high-bandwidth exchange of
                        ideas and opportunities.
                    </p>
                </div>

                <!-- 5. Community & Contact -->
                <div class="col-span-1 md:col-span-6 lg:col-span-12 pt-8">
                    <h2
                        class="text-2xl font-display uppercase tracking-tight mb-6 flex items-center gap-4 text-muted-foreground"
                    >
                        <span class="text-primary">Join The Network</span>
                        <div class="h-px flex-1 bg-border"></div>
                    </h2>
                </div>

                <!-- Telegram Main (Large) -->
                <a
                    href="https://t.me/+iOXKIVLSYcw5OTA1"
                    target="_blank"
                    class="col-span-1 md:col-span-3 lg:col-span-4 p-6 border border-border bg-card/20 hover:border-primary hover:bg-card/40 transition-all group flex flex-col h-40 justify-between"
                >
                    <div class="flex items-start justify-between">
                        <div
                            class="p-2 bg-background/50 rounded-sm border border-border group-hover:border-primary/50 transition-colors"
                        >
                            <IconSend
                                className="h-5 w-5 text-muted-foreground group-hover:text-primary transition-colors"
                            />
                        </div>
                        <IconArrowRight
                            className="h-5 w-5 text-muted-foreground group-hover:text-primary group-hover:-translate-y-1 group-hover:translate-x-1 transition-transform"
                        />
                    </div>
                    <div>
                        <h3
                            class="font-display text-lg uppercase tracking-tight group-hover:text-primary transition-colors"
                        >
                            Telegram Discussion
                        </h3>
                        <p class="text-xs text-muted-foreground font-mono mt-1">Global broadcast. 500+ members.</p>
                    </div>
                </a>

                <!-- Telegram Alerts (Large) -->
                <a
                    href="https://t.me/nusaisociety"
                    target="_blank"
                    class="col-span-1 md:col-span-3 lg:col-span-4 p-6 border border-border bg-card/20 hover:border-primary hover:bg-card/40 transition-all group flex flex-col h-40 justify-between"
                >
                    <div class="flex items-start justify-between">
                        <div
                            class="p-2 bg-background/50 rounded-sm border border-border group-hover:border-primary/50 transition-colors"
                        >
                            <IconSend
                                className="h-5 w-5 text-muted-foreground group-hover:text-primary transition-colors"
                            />
                        </div>
                        <IconArrowRight
                            className="h-5 w-5 text-muted-foreground group-hover:text-primary group-hover:-translate-y-1 group-hover:translate-x-1 transition-transform"
                        />
                    </div>
                    <div>
                        <h3
                            class="font-display text-lg uppercase tracking-tight group-hover:text-primary transition-colors"
                        >
                            Telegram Alerts
                        </h3>
                        <p class="text-xs text-muted-foreground font-mono mt-1">Official announcements. No noise.</p>
                    </div>
                </a>

                <!-- Discord (Large) -->
                <a
                    href="https://discord.com/invite/yazkAEsjww"
                    target="_blank"
                    class="col-span-1 md:col-span-6 lg:col-span-4 p-6 border border-border bg-card/20 hover:border-primary hover:bg-card/40 transition-all group flex flex-col h-40 justify-between"
                >
                    <div class="flex items-start justify-between">
                        <div
                            class="p-2 bg-background/50 rounded-sm border border-border group-hover:border-primary/50 transition-colors"
                        >
                            <IconMessageCircle className="h-5 w-5 text-primary" />
                        </div>
                        <div
                            class="px-2 py-1 border border-primary/20 rounded-full text-[10px] font-mono text-primary uppercase bg-primary/5 group-hover:bg-primary group-hover:text-primary-foreground transition-all"
                        >
                            Join Server
                        </div>
                    </div>
                    <div>
                        <h3
                            class="font-display text-lg uppercase tracking-tight group-hover:text-primary transition-colors"
                        >
                            Discord Workspace
                        </h3>
                        <p class="text-xs text-muted-foreground font-mono mt-1">The central operating system.</p>
                    </div>
                </a>

                <!-- LinkedIn -->
                <a
                    href="https://www.linkedin.com/company/nus-computing-ai-society/"
                    target="_blank"
                    class="col-span-1 md:col-span-3 lg:col-span-3 p-4 border border-border bg-card/20 hover:border-primary hover:bg-card/40 transition-all group flex items-center gap-4"
                >
                    <div
                        class="p-2 bg-background/50 rounded-sm border border-border group-hover:border-primary/50 transition-colors"
                    >
                        <IconBrandLinkedin
                            className="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors"
                        />
                    </div>
                    <span
                        class="font-display text-sm uppercase tracking-tight group-hover:text-primary transition-colors"
                        >LinkedIn</span
                    >
                </a>

                <!-- X (Twitter) -->
                <a
                    href="https://x.com/socaisociety"
                    target="_blank"
                    class="col-span-1 md:col-span-3 lg:col-span-3 p-4 border border-border bg-card/20 hover:border-primary hover:bg-card/40 transition-all group flex items-center gap-4"
                >
                    <div
                        class="p-2 bg-background/50 rounded-sm border border-border group-hover:border-primary/50 transition-colors"
                    >
                        <IconBrandTwitter
                            className="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors"
                        />
                    </div>
                    <span
                        class="font-display text-sm uppercase tracking-tight group-hover:text-primary transition-colors"
                        >X / Twitter</span
                    >
                </a>

                <!-- Email -->
                <a
                    href="mailto:contact@nusaisociety.org"
                    class="col-span-1 md:col-span-3 lg:col-span-3 p-4 border border-border bg-card/20 hover:border-primary hover:bg-card/40 transition-all group flex items-center gap-4"
                >
                    <div
                        class="p-2 bg-background/50 rounded-sm border border-border group-hover:border-primary/50 transition-colors"
                    >
                        <IconMail
                            className="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors"
                        />
                    </div>
                    <span
                        class="font-display text-sm uppercase tracking-tight group-hover:text-primary transition-colors"
                        >Email</span
                    >
                </a>

                <!-- Hugging Face -->
                <a
                    href="https://huggingface.co/socaisociety"
                    target="_blank"
                    class="col-span-1 md:col-span-3 lg:col-span-3 p-4 border border-border bg-card/20 hover:border-primary hover:bg-card/40 transition-all group flex items-center gap-4"
                >
                    <div
                        class="p-2 bg-background/50 rounded-sm border border-border group-hover:border-primary/50 transition-colors"
                    >
                        <IconRobot
                            className="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors"
                        />
                    </div>
                    <span
                        class="font-display text-sm uppercase tracking-tight group-hover:text-primary transition-colors"
                        >Hugging Face</span
                    >
                </a>
            </div>
        </main>
    </div>
</BaseLayout>
