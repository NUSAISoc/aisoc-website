---
/**
 * EventCardPlaceholder - Abstract circuit-grid pattern with date display
 * Used when an event doesn't have a cover image
 */
import { format } from "date-fns";

interface Props {
    date: Date;
    slug: string;
}

const { date, slug } = Astro.props;
---

<div class="absolute inset-0 opacity-20">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <pattern id={`circuit-grid-${slug}`} x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
                <path d="M 32 0 L 0 0 0 32" fill="none" stroke="currentColor" stroke-width="0.5" class="text-primary"
                ></path>
                <circle cx="0" cy="0" r="2" fill="currentColor" class="text-primary/50"></circle>
                <circle cx="32" cy="32" r="1.5" fill="currentColor" class="text-secondary"></circle>
            </pattern>
        </defs>
        <rect width="100%" height="100%" fill={`url(#circuit-grid-${slug})`}></rect>
    </svg>
</div>

<!-- Diagonal accent lines -->
<div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-4 -left-4 w-24 h-24 border-b border-primary/30 rotate-45 translate-x-8 translate-y-4">
    </div>
    <div class="absolute -bottom-4 -right-4 w-20 h-20 border-t border-secondary/30 rotate-45"></div>
</div>

<!-- Large date display -->
<div class="absolute inset-0 flex flex-col items-center justify-center">
    <span class="text-5xl font-display font-bold text-primary/80 tracking-tighter">
        {format(date, "dd")}
    </span>
    <span class="text-lg font-mono uppercase text-muted-foreground tracking-widest">
        {format(date, "MMM yyyy")}
    </span>
</div>

<!-- Corner brackets -->
<div class="absolute top-3 left-3 w-4 h-4 border-l-2 border-t-2 border-primary/40"></div>
<div class="absolute top-3 right-3 w-4 h-4 border-r-2 border-t-2 border-primary/40"></div>
<div class="absolute bottom-3 left-3 w-4 h-4 border-l-2 border-b-2 border-secondary/40"></div>
<div class="absolute bottom-3 right-3 w-4 h-4 border-r-2 border-b-2 border-secondary/40"></div>
