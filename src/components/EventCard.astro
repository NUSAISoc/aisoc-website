---
import { format } from "date-fns";
import { IconCalendar, IconMapPin, IconClock, IconArrowRight } from "@tabler/icons-react";
import EventCardPlaceholder from "@/components/placeholders/EventCardPlaceholder.astro";

interface Props {
    slug: string;
    event: {
        data: {
            title: string;
            date: Date | string;
            time: string;
            location: string;
            status: "upcoming" | "past";
            image?: string;
            description?: string;
        };
    };
}

const { slug, event } = Astro.props;
const { title, date, time, location, status, image, description } = event.data;
const dateObj = typeof date === "string" ? new Date(date) : date;
const isUpcoming = status === "upcoming";
---

<a href={`/events/${slug}`} class="block h-full no-underline">
    <div
        class:list={[
            "group cursor-pointer transition-all hover:border-primary/50 hover:bg-muted/10 h-full flex flex-col overflow-hidden rounded-xl border bg-card text-card-foreground shadow-sm pt-0 gap-0",
            isUpcoming ? "border-primary/20" : "border-border opacity-80 hover:opacity-100",
        ]}
    >
        <!-- Card Image / Placeholder -->
        <div
            class:list={[
                "relative aspect-[2.5/1] w-full overflow-hidden border-b border-border",
                image ? "bg-muted" : "bg-muted/30",
            ]}
        >
            {
                image ? (
                    <Fragment>
                        <img
                            src={image}
                            alt={title}
                            class="h-full w-full object-cover transition-all duration-500 group-hover:scale-105 opacity-50 grayscale group-hover:opacity-70 group-hover:grayscale-0"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-background via-background/60 to-background/30" />
                    </Fragment>
                ) : (
                    <EventCardPlaceholder date={dateObj} slug={slug} />
                )
            }

            {
                isUpcoming && (
                    <div class="absolute top-2 right-2">
                        <span class="inline-flex items-center rounded-md border border-transparent bg-primary px-2.5 py-0.5 text-xs font-semibold text-primary-foreground font-mono animate-pulse">
                            UPCOMING
                        </span>
                    </div>
                )
            }
        </div>

        <!-- Card Header -->
        <div class="flex flex-col space-y-1.5 p-6 pt-4 space-y-2">
            <h3
                class="font-display text-xl uppercase tracking-tight group-hover:text-primary transition-colors leading-tight"
            >
                {title}
            </h3>
            <div class="space-y-1 text-xs text-muted-foreground font-mono">
                <div class="flex items-center gap-4">
                    <span class="flex items-center">
                        <IconCalendar className="mr-1 h-3 w-3" />
                        {format(dateObj, "dd MMM yyyy")}
                    </span>
                    <span class="flex items-center">
                        <IconClock className="mr-1 h-3 w-3" />
                        {time}
                    </span>
                </div>
                <div class="flex items-center">
                    <IconMapPin className="mr-1 h-3 w-3" />
                    {location}
                </div>
            </div>
        </div>

        <!-- Card Content -->
        <div class="p-6 pt-0 flex-1 mt-2 pb-4">
            {
                description && (
                    <p class="text-sm text-muted-foreground font-mono leading-relaxed line-clamp-2">{description}</p>
                )
            }
        </div>

        <!-- Card Footer -->
        <div class="flex items-center p-6 pt-0 border-t border-border pt-4 mt-auto">
            <span
                class="text-xs font-mono text-primary group-hover:translate-x-1 transition-transform inline-flex items-center"
            >
                [ ACCESS_DETAILS ] <IconArrowRight className="ml-1 h-3 w-3" />
            </span>
        </div>
    </div>
</a>
